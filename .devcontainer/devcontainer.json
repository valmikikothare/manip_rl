{
	"name": "manip-rl (ROCm)",
	"image": "rocm/dev-ubuntu-24.04:7.2.4-complete",
	"remoteUser": "ubuntu",
	"features": {
		"ghcr.io/rocker-org/devcontainer-features/apt-packages:1": {
			"packages": "libdw1"
		},
		"ghcr.io/devcontainers/features/common-utils:2": {
			"installZsh": false,
			"username": "ubuntu"
		},
		"ghcr.io/devcontainers-extra/features/ripgrep:1": {},
		"ghcr.io/devcontainers-extra/features/uv:1": {},
		"ghcr.io/devcontainers-extra/features/starship:1": {},
		"ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
	},
	"mounts": [
		"source=claude-code-config-${devcontainerId},target=/claude,type=volume",
		"source=uv-cache-${devcontainerId},target=/uv-cache,type=volume"
	],
	"runArgs": [
		// CDI spec (/etc/cdi/amd.json, generated by amd-container-toolkit)
		// injects /dev/kfd + /dev/dri with world-rw perms — no group-add or
		// manual --device needed. If CDI isn't set up on the host, replace this
		// line with:
		//   "--device=/dev/kfd", "--device=/dev/dri", "--group-add=video"
		"--device=amd.com/gpu=all",
		"--shm-size=8g"
	],
	"containerEnv": {
		// gfx1032 (RX 6650 XT / 6800S) is unsupported; impersonate gfx1030.
		"HSA_OVERRIDE_GFX_VERSION": "10.3.0",
		// dGPU only — hide the Radeon 680M iGPU so device enumeration is stable.
		"ROCR_VISIBLE_DEVICES": "0",
		"LLVM_PATH": "/opt/rocm/llvm",
		"UV_LINK_MODE": "copy",
		"UV_CACHE_DIR": "/uv-cache",
		"CLAUDE_CONFIG_DIR": "/claude"
	},
	"onCreateCommand": "sudo chown -R ubuntu:ubuntu /claude /uv-cache",
	"postCreateCommand": "uv sync --extra rocm",
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"mads-hartmann.bash-ide-vscode",
				"charliermarsh.ruff",
				"tamasfe.even-better-toml",
				"Anthropic.claude-code",
				"DavidAnson.vscode-markdownlint",
				"redhat.vscode-yaml"
			],
			"settings": {
				"python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python"
			}
		}
	}
}